# Основной домен: сайт + API (один TLS-сертификат — без hostname mismatch в клиенте)
arc303.ru, www.arc303.ru {
  encode zstd gzip

  handle /health {
    reverse_proxy creative_collective_api:3000
  }

  handle /api/* {
    reverse_proxy creative_collective_api:3000
  }

  handle {
    root * /srv
    file_server
  }
}

# Поддомен API (отдельный cert; если 502/mismatch — используй https://arc303.ru/api/v1)
api.arc303.ru {
  encode zstd gzip
  reverse_proxy creative_collective_api:3000
}
