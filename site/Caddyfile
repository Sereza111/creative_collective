# Один TLS-сертификат на все имена (Let's Encrypt через Caddy)
# После смены конфига: удалить volume caddy_data в Portainer и redeploy стека.

arc303.ru, www.arc303.ru, api.arc303.ru {
  encode zstd gzip

  # Поддомен api — весь трафик в backend
  @apiHost host api.arc303.ru
  handle @apiHost {
    reverse_proxy creative_collective_api:3000
  }

  # Основной домен: API по путям
  handle /health {
    reverse_proxy creative_collective_api:3000
  }

  handle /api/* {
    reverse_proxy creative_collective_api:3000
  }

  # Основной домен: лендинг
  handle {
    root * /srv
    file_server
  }
}
