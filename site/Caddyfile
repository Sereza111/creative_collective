# Замени email на свой (для Let's Encrypt)
{
  email admin@arc303.ru
}

# Сайт + API на основном домене (один сертификат)
arc303.ru {
  encode zstd gzip

  handle /health {
    reverse_proxy creative_collective_api:3000
  }

  handle /api/* {
    reverse_proxy creative_collective_api:3000
  }

  handle {
    root * /srv
    file_server
  }
}

# API на поддомене (отдельный сертификат)
# www.arc303.ru НЕ в списке — у тебя DNS www → 5.101.152.161 (другой сервер), из-за этого LE падает
api.arc303.ru {
  encode zstd gzip
  reverse_proxy creative_collective_api:3000
}
